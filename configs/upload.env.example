# TapirXL log shipper environment variables.
#
# Copy to configs/upload.env (gitignored) for local development, or
# render this template into a systemd EnvironmentFile / docker env_file
# for compose deployments.
#
# Consumed by configs/upload-vector.toml at Vector startup.

# Required: BlueFlow API base URL. Compose service example:
#   BLUEFLOW_URL=http://blueflow-api:8000
# Local dev against a port-forwarded instance:
#   BLUEFLOW_URL=http://127.0.0.1:8000
BLUEFLOW_URL=http://127.0.0.1:8000

# Required: DRF auth token issued by BlueFlow's /api/api-token-auth/.
# Sent on every request as: "Authorization: Token <hex>".
# Treat as a secret; prefer file-based mounting in compose:
#   secrets:
#     blueflow_token: { file: ./secrets/blueflow_token }
# and read into BLUEFLOW_TOKEN at container start.
BLUEFLOW_TOKEN=replace-me-with-a-real-token

# Optional: path the file source tails for InventoryRecord JSONL.
# Defaults to /var/lib/tapirxl/inventory.jsonl (compose shared volume).
TAPIRXL_INVENTORY_FILE=/var/lib/tapirxl/inventory.jsonl

# Optional: Vector data directory (checkpoints + disk buffer).
# Defaults to /var/lib/vector/data inside the container.
VECTOR_DATA_DIR=/var/lib/vector/data
